{%- comment -%}
  MODULE: hotel_reco_grid_4
  Data: rec_hotels (array 0-4), reco_city (string)
  Config (from CSV): hotel_reco_headline, hotel_reco_type
  hotel_reco_headline: use {city} as placeholder for reco_city. E.g. "Recently viewed hotels in {city}" or "Great alternatives in {city}"
  hotel_reco_type: last_browsed | similar_to_last_viewed | top_in_destination
  similar_to_last_viewed: no per-card CTA, booking details in header, single "See more deals" button.
  API for similar: reco_booking_dates (e.g. "Nov 4 - Nov 7 (3 nights)"), reco_booking_guests (e.g. "2 Guests, 1 room"), reco_see_more_url
  hotel_reco_cta_text, hotel_reco_cta_url: optional extra CTA below recommenders. If hotel_reco_cta_text is empty, CTA is not rendered.
  Renders header + 4 hotel cards in 2x2 grid. Desktop: 2 per row. Mobile: stacked.
{%- endcomment -%}
{%- assign CONTAINER_WIDTH = 728 -%}
{%- assign CARD_GUTTER = 16 -%}
{%- assign PLACEHOLDER_IMAGE_URL = "https://userimg-assets.customeriomail.com/images/client-env-124967/1746098547647_hotel_card_3_01JT5SAV0XEHV7NKYWXWKKM4RB.png" -%}
{%- assign STAR_ICON_URL = "https://userimg-assets.customeriomail.com/images/client-env-124967/1772554872554_Icon_V3_01KJT81STKGWBRBWNSNCBKHVYK.png" -%}

{%- assign _city = reco_city | default: "Barcelona" -%}
{%- assign _h = hotel_reco_headline | default: "Recently viewed hotels in {city}" -%}
{%- assign _parts = _h | split: "{city}" -%}
{%- assign _reco_type = hotel_reco_type | default: "last_browsed" | strip | downcase -%}
{%- assign _is_similar = false -%}
{%- if _reco_type == "similar_to_last_viewed" or _reco_type == "similar" -%}{%- assign _is_similar = true -%}{%- endif -%}
{%- if rec_hotels != blank and rec_hotels.size > 0 -%}
<style type="text/css">
  @media only screen and (max-width: 600px) {
    .hotel-reco-card-wrap { display: block !important; width: 100% !important; max-width: 100% !important; }
    .hotel-reco-card-inner { width: 100% !important; max-width: 100% !important; }
  }
</style>
<!-- MODULE: hotel_reco_grid_4 START -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="width:100%;border-collapse:collapse;background-color:#ffffff;">
  <tr>
    <td align="center" style="padding:24px 16px 16px 16px;">
      <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" style="width:100%;max-width:{{ CONTAINER_WIDTH }}px;border-collapse:collapse;">
        {%- comment -%} Frame 1000001741: flex column, gap 8px, align-items flex-start, padding 0 {%- endcomment -%}
        <tr>
          <td style="padding:0;text-align:left;">
            <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="width:100%;border-collapse:collapse;">
              <tr>
                <td style="padding:0 0 {% if _is_similar %}8px{% else %}24px{% endif %} 0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:20px;line-height:28px;font-weight:600;letter-spacing:0.2px;color:#0F0E0F;text-align:left;">
                  {{ _parts | first }}<span style="color:#7130c9;">{{ _city }}</span>{% if _parts.size > 1 %}{{ _parts | last }}{% endif %}
                </td>
              </tr>
              {%- if _is_similar -%}
              <tr>
                <td style="padding:0 0 16px 0;font-size:14px;line-height:22px;color:#0F0E0F;letter-spacing:0.14px;text-align:left;">
                  {%- assign _dates = reco_booking_dates | default: "" -%}
            {%- assign _guests = reco_booking_guests | default: "" -%}
            {%- if _dates == blank and rec_hotels.size > 0 -%}
              {%- assign _first = rec_hotels | first -%}
              {%- assign _n = _first.nights | default: 1 -%}
              {%- assign _nlab = _n | append: " nights" -%}
              {%- if _n == 1 -%}{%- assign _nlab = "1 night" -%}{%- endif -%}
              {%- assign _dates = _first.checkin | default: "" | append: " - " | append: _first.checkout | default: "" | append: " (" | append: _nlab | append: ")" -%}
            {%- endif -%}
            {%- if _dates != blank -%}<span style="color:#0F0E0F;">&#128197;</span> {{ _dates }}{% endif -%}
            {%- if _dates != blank and _guests != blank -%}&nbsp;&nbsp;·&nbsp;&nbsp;{%- endif -%}
            {%- if _guests != blank -%}<span style="color:#0F0E0F;">&#128100;</span> {{ _guests }}{% endif -%}
                </td>
              </tr>
              {%- else -%}
              <tr><td style="padding:0 0 16px 0;"></td></tr>
              {%- endif -%}
            </table>
          </td>
        </tr>
        <tr>
          <td>
            {%- comment -%} Row 1: cards 0,1 {%- endcomment -%}
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="width:100%;border-collapse:collapse;">
              <tr>
                {%- for hotel in rec_hotels limit: 4 -%}
                {%- assign idx = forloop.index0 -%}
                {%- if idx == 2 -%}
              </tr>
              <tr>
                {%- endif -%}
                <td class="hotel-reco-card-wrap" valign="top" width="50%" style="width:50%;max-width:356px;vertical-align:top;padding:0 8px {{ CARD_GUTTER }}px 0;">
                  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="hotel-reco-card-inner" style="width:100%;max-width:356px;border-collapse:separate;border-spacing:0;border:1px solid #EDEAE7;border-radius:8px;overflow:hidden;background-color:#ffffff;">
                    <tr>
                      <td>
                        {%- if hotel.image_url != blank -%}
                          {%- assign img_url = hotel.image_url -%}
                        {%- else -%}
                          {%- assign img_url = PLACEHOLDER_IMAGE_URL -%}
                        {%- endif -%}
                        {%- assign link_url = hotel.deeplink | default: "#" -%}
                        <a href="{{ link_url }}" target="_blank" style="display:block;text-decoration:none;border:0;outline:none;">
                          <img src="{{ img_url }}" alt="{{ hotel.name | escape }}" width="340" height="200" style="display:block;width:100%;max-width:340px;height:200px;object-fit:cover;border:0;outline:none;" />
                        </a>
                      </td>
                    </tr>
                    <tr>
                      <td style="padding:8px 8px 12px 8px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
                        {%- assign stars = hotel.stars | default: 5 -%}
                        <p style="margin:0 0 4px 0;font-size:12px;line-height:16px;color:#505050;letter-spacing:0;">
                          {%- for i in (1..5) -%}<img src="{{ STAR_ICON_URL }}" alt="★" width="12" height="12" style="display:inline-block;vertical-align:middle;width:12px;height:12px;margin-right:4px;border:0;{%- if i > stars -%}opacity:0.35;{%- endif -%}" />{%- endfor -%}
                        </p>
                        {%- assign name_len = hotel.name | size -%}
                        {%- if name_len > 36 -%}
                          {%- assign name_display = hotel.name | slice: 0, 33 | append: "…" -%}
                        {%- else -%}
                          {%- assign name_display = hotel.name -%}
                        {%- endif -%}
                        <p style="margin:0 0 4px 0;font-size:16px;line-height:24px;font-weight:500;color:#0F0E0F;">
                          <a href="{{ link_url }}" target="_blank" style="color:#0F0E0F;text-decoration:none;font-weight:500;">{{ name_display }}</a>
                        </p>
                        {%- unless _is_similar -%}
                        <p style="margin:0 0 4px 0;font-size:12px;line-height:16px;font-weight:400;letter-spacing:0.12px;color:#696663;">{{ hotel.city | default: "" }}</p>
                        {%- endunless -%}
                        {%- if hotel.review_score != blank -%}
                        <p style="margin:0 0 4px 0;font-size:12px;line-height:16px;">
                          <span style="color:#3E9C32;font-weight:500;">{{ hotel.review_score }}</span>
                          <span style="color:#0F0E0F;font-weight:500;"> {{ hotel.review_label | default: "" }}</span>
                          <span style="color:#6C6770;font-weight:450;"> ({{ hotel.review_count | default: 0 }})</span>
                        </p>
                        {%- endif -%}
                        {%- unless _is_similar -%}
                        {%- assign nights = hotel.nights | default: 1 -%}
                        {%- if nights == 1 -%}
                          {%- assign nights_label = "1 night" -%}
                        {%- else -%}
                          {%- assign nights_label = nights | append: " nights" -%}
                        {%- endif -%}
                        <p style="margin:0 0 4px 0;font-size:12px;line-height:16px;font-weight:450;color:#0F0E0F;">{{ hotel.checkin | default: "" }} - {{ hotel.checkout | default: "" }} ({{ nights_label }})</p>
                        {%- endunless -%}
                        <p style="margin:0;font-size:20px;line-height:28px;font-weight:500;color:#0F0E0F;">
                          {{ hotel.currency_symbol | default: "$" }}{{ hotel.price | round }} <span style="font-size:12px;line-height:16px;font-weight:450;color:#696663;">/ night</span>
                        </p>
                      </td>
                    </tr>
                  </table>
                </td>
                {%- if idx == 2 and rec_hotels.size == 3 -%}
                <td class="hotel-reco-card-wrap" valign="top" width="50%" style="width:50%;max-width:356px;vertical-align:top;padding:0 8px {{ CARD_GUTTER }}px 0;">
                  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="width:100%;max-width:356px;border-collapse:collapse;">
                    <tr><td style="height:1px;line-height:1px;font-size:1px;border:0;">&nbsp;</td></tr>
                  </table>
                </td>
                {%- endif -%}
                {%- endfor -%}
              </tr>
            </table>
            {%- if _is_similar -%}
            <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" style="width:100%;max-width:{{ CONTAINER_WIDTH }}px;border-collapse:collapse;">
              <tr>
                <td align="center" style="padding:24px 0 0 0;">
                  {%- assign _see_more_url = reco_see_more_url | default: "#" -%}
                  <a href="{{ _see_more_url }}" target="_blank" style="display:inline-block;padding:12px 32px;font-size:16px;line-height:20px;font-weight:600;color:#0F0E0F;text-decoration:none;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;background-color:#ffffff;border:1px solid #d1d5db;border-radius:8px;">See more deals</a>
                </td>
              </tr>
            </table>
            {%- endif -%}
            {%- assign _cta_text = hotel_reco_cta_text | default: "" | strip -%}
            {%- if _cta_text != blank -%}
            <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" style="width:100%;max-width:{{ CONTAINER_WIDTH }}px;border-collapse:collapse;">
              <tr>
                <td align="center" style="padding:16px 0 0 0;">
                  {%- assign _cta_url = hotel_reco_cta_url | default: "#" | strip -%}
                  {%- if _cta_url == blank -%}{%- assign _cta_url = "#" -%}{%- endif -%}
                  <a href="{{ _cta_url }}" target="_blank" style="display:inline-block;padding:12px 32px;font-size:16px;line-height:20px;font-weight:600;color:#0F0E0F;text-decoration:none;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;background-color:#ffffff;border:1px solid #d1d5db;border-radius:8px;">{{ _cta_text }}</a>
                </td>
              </tr>
            </table>
            {%- endif -%}
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
<!-- MODULE: hotel_reco_grid_4 END -->
{%- else -%}
{%- comment -%} Dummy block when rec_hotels is blank (preview / structure check) {%- endcomment -%}
<style type="text/css">
  @media only screen and (max-width: 600px) {
    .hotel-reco-card-wrap { display: block !important; width: 100% !important; max-width: 100% !important; }
    .hotel-reco-card-inner { width: 100% !important; max-width: 100% !important; }
  }
</style>
